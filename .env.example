# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=https://solonreview.dev

# ─── GitHub OAuth App ────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: https://solonreview.dev
# Callback URL: https://solonreview.dev/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Neon (Postgres) ─────────────────────────────────────────────────────────
# Create free account at: https://neon.tech
# Copy the connection string from: Neon Dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# Dashboard → Webhooks → signing secret (set endpoint: /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Dashboard → Products → your $29/mo price → price_...
STRIPE_PRICE_ID=price_your-stripe-price-id
